# Python
.venv/
__pycache__/
*.pyc
*.pyo
.env
.env.*              ← ignore any .env variant (.env.local etc)

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
*.tfvars            ← terraform variable files can contain secrets
*.tfvars.json

# Airflow
logs/
airflow.db          ← local sqlite db if ever used

# Secrets
secrets/
service-account-key.json
*.json.key
*service-account*   ← catches any service account file variation
*.pem
*.p12

# OS
.DS_Store           ← you're on Mac, this will appear everywhere
.idea/              ← if you ever open in JetBrains
.vscode/settings.json  ← personal VS Code settings

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/